# Server-only — forwarded by the BFF as X-Api-Key (never expose to the browser).
BOND_API_BASE_URL=https://public.api.squad-c.bondsports.co
BOND_API_KEY=

# Bond auth host (consumer login + refresh) — server-only proxy at /api/bond-auth/*
BOND_AUTH_BASE_URL=https://api.squad-c.bondsports.co

# Public — org and portal the UI loads (from Bond backoffice).
NEXT_PUBLIC_BOND_ORG_ID=155
NEXT_PUBLIC_BOND_PORTAL_ID=133

# When "true", show Timeline (matrix) alongside List in booking. Omit or false = list only (production default).
# Required in .env.local to try Timeline + schedule-band experiments on branch experiment/booking-timeline-when-band.
# NEXT_PUBLIC_BOOKING_TIMELINE_ENABLED=true
